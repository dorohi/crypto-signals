{
  "name": "crypto-signals",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:monitor": "pnpm --filter monitor dev",
    "dev": "concurrently \"pnpm run dev:api\" \"pnpm run dev:web\" \"pnpm run dev:monitor\"",
    "build": "pnpm --filter @crypto-signals/shared build && pnpm --filter @crypto-signals/db build && pnpm --filter api build && pnpm --filter web build && pnpm --filter monitor build",
    "db:generate": "pnpm --filter @crypto-signals/db prisma generate",
    "db:push": "pnpm --filter @crypto-signals/db prisma db push",
    "db:seed": "pnpm --filter @crypto-signals/db prisma db seed",
    "db:studio": "pnpm --filter @crypto-signals/db prisma studio"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ]
  }
}
